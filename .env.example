# Backend API base URL (no trailing slash)
# Local: http://localhost:1337
# Production (App Engine): https://api-industry-dev.mindmatrix.io
VITE_API_URL=http://localhost:1337

# Optional: Strapi API token with full access. When set, used for all API requests (instead of login JWT).
# Create in Strapi Admin: Settings → API Tokens. Do not commit the real token.
# VITE_API_TOKEN=your_api_token_here
